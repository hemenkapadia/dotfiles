# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

# Inserts a blank line between shell prompts
add_newline = true

# Prompt format using fill to separate left and right prompts
format = """$username $hostname $directory $git_branch $git_metrics$fill$all$character"""

# Dynamically fill the gap between left and right prompts
[fill]
symbol = ' '

# Replace the '❯' symbol in the prompt with '➜'
[character] # The name of the module we are configuring is 'character'
success_symbol = '✅'
error_symbol = '⛔'

[username]
style_user = '#e4e200 bold'
style_root = 'red bold'
format = '[$user]($style)'
disabled = false
show_always = true

[hostname]
ssh_only = false
ssh_symbol = '📡'
format = '[$hostname](bold #7070ea) [$ssh_symbol](bold blue)'
trim_at = 'hemen.home.arpa'
disabled = false
aliases = {
  "ip-10-18-34-201" = "AWS-Workstation",
  "hkapadia-dell15" = "Office-Laptop",
  "hp-11-ak1035nr" = "Home-Laptop-HP"
}

[directory]
truncation_length = 2
truncation_symbol = '…/'
truncate_to_repo = true
format = '[$path]($style)[$read_only]($read_only_style)'

[git_branch]
format = '[$symbol$branch(:$remote_branch)]($style)'
# ~/.config/starship.toml

[git_metrics]
disabled = false
added_style = 'bold blue'
format = '[+$added]($added_style)/[-$deleted]($deleted_style)'

[aws]
disabled = false
symbol = '☁️ '
format = '[$symbol $profile (\[$duration\])]($style) '
style = 'blue yellow'

[gcloud]
disabled = false
symbol = '☁️ '
format = '[$symbol $project]($style) '
style = '#DB4437 bold'


[azure]
disabled = false
format = '[$symbol $subscription]($style)'
symbol = '☁️ '
style = 'blue bold'
