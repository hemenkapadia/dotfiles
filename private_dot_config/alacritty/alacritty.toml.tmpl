# Alacritty Configuration
# Reference: https://alacritty.org/config-alacritty.html

# =============================================================================
# GENERAL
# =============================================================================
[general]

# Import additional configuration files. Entries are resolved relative to the
# directory of the config file. Glob patterns are allowed.
import = []

# Directory the shell is started in. "None" means use the parent process's
# working directory.
working_directory = "None"

# Live config reload (changes require restart if this is disabled).
live_config_reload = true

# Offer IPC using `alacritty msg` (Unix only).
ipc_socket = true


# =============================================================================
# ENV
# Key/value pairs added as environment variables for every spawned process.
# Example: WINIT_X11_SCALE_FACTOR = "1"
# =============================================================================
[env]


# =============================================================================
# WINDOW
# =============================================================================
[window]

# Window dimensions in character columns and lines (not pixels). A value of
# 0 for both means the OS/WM picks the size.
dimensions = { columns = 0, lines = 0 }

# Window startup position in pixels. No effect on Wayland.
# "None" lets the OS/WM decide; or use { x = 0, y = 0 }.
position = "None"

# Blank space around window content in pixels. Applied before DPI scaling.
padding = { x = 0, y = 0 }

# Spread any extra padding evenly around the terminal content so the cell
# grid is centred when the window is not an exact multiple of the cell size.
dynamic_padding = false

# Window decorations.
# Options: "Full"         - Borders and title bar
#          "None"         - No borders or title bar
#          "Transparent"  - Title bar with transparent background (macOS)
#          "Buttonless"   - Title bar without traffic-light buttons (macOS)
decorations = "Full"

# Background opacity: 0.0 = fully transparent, 1.0 = fully opaque.
opacity = 1.0

# Ask the compositor to blur content behind transparent windows.
# Supported on macOS and KDE Wayland.
blur = false

# Window state on launch. Changes require a restart.
# Options: "Windowed"         - Regular window
#          "Maximized"        - Start maximised
#          "Fullscreen"       - Start in fullscreen
#          "SimpleFullscreen" - macOS non-native fullscreen
{{ if eq .chezmoi.config.data.profile "home-laptop" }}
startup_mode = "Fullscreen"
{{ else }}
startup_mode = "Windowed"
{{ end }}

# Window title text.
title = "Alacritty"

# Allow terminal apps to change the title via OSC escape sequences.
dynamic_title = true

# Window class reported to the window manager (Linux/BSD only).
# Sets WM_CLASS instance name and general class name.
class = { instance = "Alacritty", general = "Alacritty" }

# Override the system theme variant used for window decorations.
# Options: "Dark" | "Light" | "None" (use system default)
decorations_theme_variant = "None"

# Prefer resizing the terminal in discrete steps equal to the cell size.
# Applies on macOS and X11; ignored elsewhere.
resize_increments = false

# Make the Option key behave as Alt (macOS only).
# Options: "OnlyLeft" | "OnlyRight" | "Both" | "None" (macOS default behaviour)
option_as_alt = "None"

# Window z-order level.
# Options: "Normal" | "AlwaysOnTop"
# Not working 
# level = "Normal"


# =============================================================================
# SCROLLING
# =============================================================================
[scrolling]

# Maximum number of lines kept in the scrollback buffer. 0 disables scrolling.
# Maximum allowed value is 100000.
history = 10000

# Number of lines scrolled per scroll-wheel increment.
multiplier = 3


# =============================================================================
# FONT
# =============================================================================
[font]

# Default (normal) font face.
# Linux/BSD default family: "monospace"; Windows: "Consolas"; macOS: "Menlo".
normal = { family = "JetBrains Mono", style = "Medium" }

# Bold font face. Falls back to the normal family when not specified.
bold = { family = "JetBrains Mono", style = "Bold" }

# Italic font face. Falls back to the normal family when not specified.
italic = { family = "JetBrains Mono", style = "Italic" }

# Bold-italic font face. Falls back to the normal family when not specified.
bold_italic = { family = "JetBrains Mono", style = "Bold Italic" }

# Font size in points.
{{ if eq .chezmoi.config.data.profile "home-laptop" }}
size = 7
{{ else }}
size = 11
{{ end }}
# Extra space added around each character in pixels. Increasing offset.y
# increases vertical line spacing.
offset = { x = 0, y = 0 }

# Per-glyph placement offset within the cell. Positive y shifts the glyph
# upward. Unlike offset, this does not affect line-height calculations.
glyph_offset = { x = 0, y = 0 }

# Use the built-in font for box-drawing characters and Powerline symbols
# instead of the configured font's glyphs.
builtin_box_drawing = true


# =============================================================================
# COLORS
# =============================================================================
[colors]

# When true, window.opacity is applied to all cell backgrounds, including
# non-default ones. When false, only default-background cells are transparent.
transparent_background_colors = false

# Render bold text using the bright color variants of the palette.
draw_bold_text_with_bright_colors = false

# Primary foreground and background colors.
[colors.primary]
# Default text color.
foreground = "#d8d8d8"
# Default background color.
background = "#181818"
# Dimmed foreground; auto-calculated from foreground if omitted.
dim_foreground = "#828482"
# Bright foreground; only used when draw_bold_text_with_bright_colors is true.
bright_foreground = "None"

# Cursor colors. Accepts hex strings or the special values
# "CellForeground" / "CellBackground" to mirror the cell under the cursor.
[colors.cursor]
text   = "CellBackground"
cursor = "CellForeground"

# Vi-mode cursor colors. Accepts the same values as colors.cursor.
[colors.vi_mode_cursor]
text   = "CellBackground"
cursor = "CellForeground"

# Colors for search bar result highlights.
[colors.search.matches]
foreground = "#181818"
background = "#ac4242"

# Colors for the currently focused search match.
[colors.search.focused_match]
foreground = "#181818"
background = "#f4bf75"

# Color of the first character in a hint label (the key to press).
[colors.hints.start]
foreground = "#181818"
background = "#f4bf75"

# Color of the remaining characters in a hint label.
[colors.hints.end]
foreground = "#181818"
background = "#ac4242"

# Scrollback position indicator colors. "None" uses the inverse of the
# primary color to ensure contrast.
[colors.line_indicator]
foreground = "None"
background = "None"

# Footer bar colors used for search input and preview overlays.
[colors.footer_bar]
foreground = "#181818"
background = "#d8d8d8"

# Selection highlight colors. Accepts hex strings or
# "CellForeground" / "CellBackground".
[colors.selection]
text       = "CellBackground"
background = "CellForeground"

# Normal (ANSI) color palette — indices 0–7.
[colors.normal]
black   = "#181818"
red     = "#ac4242"
green   = "#90a959"
yellow  = "#f4bf75"
blue    = "#6a9fb5"
magenta = "#aa759f"
cyan    = "#75b5aa"
white   = "#d8d8d8"

# Bright color palette — indices 8–15.
[colors.bright]
black   = "#6b6b6b"
red     = "#c55555"
green   = "#aac474"
yellow  = "#feca88"
blue    = "#82b8c8"
magenta = "#c28cb8"
cyan    = "#93d3c3"
white   = "#f8f8f8"

# Dim color palette — used when the SGR "dim" attribute is active.
# Auto-calculated from normal colors if omitted.
[colors.dim]
black   = "#0f0f0f"
red     = "#712b2b"
green   = "#5f6f3a"
yellow  = "#a17e4d"
blue    = "#456877"
magenta = "#704d68"
cyan    = "#4d7770"
white   = "#8e8e8e"

# Override individual palette entries 16–255. Unset entries use sensible
# defaults. Each element requires an index (16–255) and a hex color string.
# Example: indexed_colors = [{ index = 16, color = "#ff9900" }]
# !! This config option results in error
# indexed_colors = []


# =============================================================================
# BELL
# =============================================================================
[bell]

# Easing curve for the visual bell flash animation.
# Options: "Ease" | "EaseOut" | "EaseOutSine" | "EaseOutQuad" | "EaseOutCubic"
#          "EaseOutQuart" | "EaseOutQuint" | "EaseOutExpo" | "EaseOutCirc" | "Linear"
animation = "Linear"

# Duration of the visual bell flash in milliseconds. 0 disables the animation.
duration = 0

# Overlay color used for the visual bell flash.
color = "#ffffff"

# Program executed when the terminal bell rings. "None" runs nothing.
# Can also be a table: { program = "notify-send", args = ["Bell"] }
command = "None"


# =============================================================================
# SELECTION
# =============================================================================
[selection]

# Characters treated as word-boundary separators during semantic (double-click)
# word selection.
semantic_escape_chars = ",│`|:\"' (){}<>\t"

# Automatically copy selected text to the primary clipboard (Linux/BSD).
save_to_clipboard = true


# =============================================================================
# CURSOR
# =============================================================================
[cursor]

# Vi-mode cursor style override. "None" re-uses the normal cursor style.
# Accepts the same shape/blinking fields as cursor.style.
vi_mode_style = "None"

# Cursor blink interval in milliseconds.
blink_interval = 750

# Seconds of inactivity before blinking stops (reduces CPU load).
# 0 means blink forever while blinking is enabled.
blink_timeout = 5

# Render the cursor as a hollow outline when the window loses focus.
unfocused_hollow = true

# Cursor thickness as a fraction of the cell width (0.0–1.0).
# Applies to the Underline and Beam cursor shapes.
thickness = 0.15

# Cursor shape and blinking behaviour.
[cursor.style]
# Cursor shape.
# Options: "Block" | "Underline" | "Beam"
shape = "Block"

# Cursor blinking policy.
# Options: "Never"  - Prevent blinking regardless of terminal requests
#          "Off"    - Default off; terminal can enable blinking
#          "On"     - Default on; terminal can disable blinking
#          "Always" - Force blinking regardless of terminal requests
blinking = "Off"


# =============================================================================
# TERMINAL
# =============================================================================
[terminal]

# Shell program and optional arguments. Defaults to $SHELL (Linux/BSD/macOS)
# or "powershell" (Windows). Can be a plain string or a table:
# shell = { program = "/bin/zsh", args = ["-l"] }
# shell = "/bin/bash"
shell = { program = "zellij" }

# OSC 52 escape sequence clipboard access.
# Options: "Disabled"  - Ignore all OSC 52 sequences
#          "OnlyCopy"  - Allow writes to clipboard only
#          "OnlyPaste" - Allow reads from clipboard only
#          "CopyPaste" - Allow both reads and writes
osc52 = "CopyPaste"


# =============================================================================
# MOUSE
# =============================================================================
[mouse]

# Hide the mouse cursor while typing; it reappears on mouse movement.
hide_when_typing = false

# Mouse button bindings. Each entry supports:
#   button - "Left" | "Right" | "Middle" | numeric button index (e.g. 5)
#   mods   - Modifier keys: "Command" | "Control" | "Option" | "Super" |
#             "Shift" | "Alt" (combinable with |)
#   mode   - Terminal mode filter (same values as keyboard bindings mode)
#   action - Action to perform (same action set as keyboard bindings)
# Example:
# [[mouse.bindings]]
# button = "Right"
# mods   = "Control"
# action = "Paste"
bindings = []


# =============================================================================
# HINTS
# =============================================================================
[hints]

# Characters used to build hint labels. Longer strings allow more simultaneous
# hints at the cost of longer labels.
alphabet = "jfkdls;ahgurieowpq"

# Hint trigger definitions. Each entry is a table with:
#   regex           - Regular expression that matches hintable text
#   hyperlinks      - Include OSC 8 hyperlinks as hints (bool)
#   post_processing - Extra processing to clean up matched text (bool)
#   persist         - Keep hint overlay open after an action (bool)
#   action          - Built-in action: "Copy" | "Paste" | "Select" | "MoveViModeCursor"
#   command         - External program to invoke with the matched text
#   binding         - Key that activates this hint: { key, mods, mode }
#   mouse           - Mouse trigger: { mods, enabled }
#
# The block below (commented out) is the built-in default that opens URLs.
# [[hints.enabled]]
# command         = "xdg-open"
# hyperlinks      = true
# post_processing = true
# persist         = false
# mouse           = { enabled = true, mods = "None" }
# binding         = { key = "U", mods = "Control|Shift" }
# regex           = "(ipfs:|ipns:|magnet:|mailto:|gemini://|gopher://|https://|http://|news:|file:|git://|ssh:|ftp://)[^\u0000-\u001F\u007F-\u009F<>\"\\s{-}\\^⟨⟩`]+"
enabled = []


# =============================================================================
# KEYBOARD
# =============================================================================
[keyboard]

# Key bindings. Each entry supports:
#   key    - Key name (e.g. "A", "F1", "Return", "Space") or scancode "0x1b"
#   mods   - Modifier keys: "Command" | "Control" | "Option" | "Super" |
#             "Shift" | "Alt" (combinable with |)
#   mode   - Terminal mode filter; prefix with ~ to negate.
#             Modes: "AppCursor" | "AppKeypad" | "Search" | "Alt" |
#             "Vi" | "FixedSizeInlineViewer"
#   action - Built-in action, e.g.:
#             "Paste" | "Copy" | "IncreaseFontSize" | "DecreaseFontSize" |
#             "ResetFontSize" | "ScrollPageUp" | "ScrollPageDown" |
#             "ScrollLineUp" | "ScrollLineDown" | "ScrollToTop" |
#             "ScrollToBottom" | "ClearHistory" | "Hide" | "Minimize" |
#             "Quit" | "ToggleFullscreen" | "SpawnNewInstance" |
#             "ClearLogNotice" | "ReceiveChar" | "None" |
#             "SearchForward" | "SearchBackward" | and many Vi mode actions
#   chars  - Send a raw byte sequence instead of an action (e.g. "\x1b[1;5A")
#
# See alacritty-bindings(5) for the full list of actions and built-in defaults.
# Example:
# [[keyboard.bindings]]
# key    = "V"
# mods   = "Control|Shift"
# action = "Paste"
bindings = []


# =============================================================================
# DEBUG
# =============================================================================
[debug]

# Overlay the frame rendering time in the top-left corner of the window.
render_timer = false

# Retain the log file after quitting. Without this the log is deleted on launch.
persistent_logging = false

# Minimum severity of messages written to the log.
# Options: "Off" | "Error" | "Warn" | "Info" | "Debug" | "Trace"
log_level = "Warn"

# Force a specific graphics renderer. "None" picks the best available option.
# Options: "glsl3"     - OpenGL 3.3 Core
#          "gles2"     - OpenGL ES 2.0
#          "gles2pure" - OpenGL ES 2.0 without extensions
#          "None"      - Automatic selection
renderer = "None"

# Log every received window event at Info level (useful for debugging input).
print_events = false

# Highlight damaged (redrawn) screen regions with a coloured overlay.
highlight_damage = false

# Use EGL as the display API when available. May improve performance on some
# drivers but can interfere with transparency.
prefer_egl = false

