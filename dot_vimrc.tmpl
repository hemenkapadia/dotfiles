"
" Vim configuration file
"

" Common Configuration
set number                                " Shows line numbers in left gutter
set numberwidth=4                         " Gutter width for numbers
set ignorecase smartcase                  " Case insensetive search; but becomes case sensetive if there is an upper case letter in search term
set modeline                              " Enable modeline to process # vim: filetype=sh etc.... settings when opening files
set encoding=utf-8                        " Use UTF-8 as its internal character set for all operations
set fileencodings=ucs-bom,utf-8,latin1    " List of character encodings for vim to try

" Set whitespace and tab settings
set tabstop=2
set shiftwidth=2
set expandtab
set list listchars=tab:→\ ,trail:·

" Navigation Configuration
" Normal Model navigation keys for ergonomic hand placement
noremap ; l
noremap l k
noremap k j
noremap j h

" Visual Configuration
{{- if eq .profile "home-kvm" }}
set term=xterm-256color
{{ else }}
set term=alacritty
{{- end }}
syntax on
syntax enable
set termguicolors
set background=dark
set t_ut=
colorscheme desert

" Statusline setup
" Clone vim liteline GitHub Repo: git clone https://github.com/itchyny/lightline.vim ~/.vim/pack/plugins/start/lightline
set laststatus=2
