#!/bin/bash

# GitHub Release Downloader Script
# This script downloads binary assets from GitHub Releases using the dra tool
# and installs them to ~/.local/bin

# set -x  # Uncomment to debug script

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
INSTALL_DIR="$HOME/.local/bin"
DRA_REPO="devmatteini/dra"
DRA_VERSION="latest"  # or specify a version like "0.6.2"

# Ensure ~/.local/bin exists
ensure_install_dir() {
    if [ ! -d "$INSTALL_DIR" ]; then
        echo -e "${YELLOW}Creating directory: $INSTALL_DIR${NC}"
        mkdir -p "$INSTALL_DIR"
    fi

    # Add to PATH if not already there
    if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
        echo -e "${YELLOW}Note: $INSTALL_DIR is not in your PATH${NC}"
        echo -e "${YELLOW}Add this line to your ~/.bashrc or ~/.zshrc:${NC}"
        echo -e "${GREEN}export PATH=\"\$HOME/.local/bin:\$PATH\"${NC}"
    fi
}

# Install dra tool
install_dra() {
    if command -v dra &> /dev/null; then
        echo -e "${GREEN}dra is already installed${NC}"
        return 0
    fi

    echo -e "${YELLOW}Installing dra tool...${NC}"

    # Detect OS and architecture
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)

    # Convert architecture names
    case $ARCH in
        x86_64)
            ARCH="x86_64"
            ;;
        aarch64|arm64)
            ARCH="aarch64"
            ;;
        armv7l)
            ARCH="armv7"
            ;;
        *)
            echo -e "${RED}Unsupported architecture: $ARCH${NC}"
            exit 1
            ;;
    esac

    # Construct download URL for dra
    if [ "$DRA_VERSION" = "latest" ]; then
        RELEASE_URL="https://github.com/$DRA_REPO/releases/latest"
        # Get the actual latest version
        ACTUAL_VERSION=$(curl -sI "$RELEASE_URL" | grep -i "location:" | grep -oP 'tag/\K[^[:space:]]+' | tr -d '\r')
        if [ -z "$ACTUAL_VERSION" ]; then
            echo -e "${RED}Failed to determine latest dra version${NC}"
            exit 1
        fi
    else
        ACTUAL_VERSION="$DRA_VERSION"
    fi

    # Download dra binary
    DRA_FILENAME="dra-${ACTUAL_VERSION}-${ARCH}-unknown-${OS}-gnu.tar.gz"
    DRA_URL="https://github.com/$DRA_REPO/releases/download/${ACTUAL_VERSION}/${DRA_FILENAME}"

    echo -e "${YELLOW}Downloading from: $DRA_URL${NC}"

    TMP_DIR=$(mktemp -d)
    cd "$TMP_DIR"

    if ! curl -fsSL -o "$DRA_FILENAME" "$DRA_URL"; then
        echo -e "${RED}Failed to download dra${NC}"
        rm -rf "$TMP_DIR"
        exit 1
    fi

    # Extract and install
    tar -xzf "$DRA_FILENAME" --strip-components=1
    chmod +x dra
    mv dra "$INSTALL_DIR/"

    # Cleanup
    cd - > /dev/null
    rm -rf "$TMP_DIR"

    echo -e "${GREEN}dra installed successfully to $INSTALL_DIR/dra${NC}"
}

# Function to download and install a binary from a GitHub repository
download_github_binary() {
    local repo="$1"
    local select_pattern="$2"
    local install_file_name="$3"

    if [ -z "$repo" ]; then
        echo -e "${RED}Error: Repository name is required (format: username/project)${NC}"
        return 1
    fi

    echo -e "${YELLOW}Downloading binary from $repo...${NC}"

    # Try automatic download with install flag
    # -a: auto-select asset for current platform
    # -i: install (extract and make executable)
    # --output: specify installation directory
    if dra download -s "$select_pattern" -i --output "$INSTALL_DIR/$install_file_name" "$repo"; then
        echo -e "${GREEN}Successfully downloaded and installed binary from $repo${NC}"
    else
        echo -e "${RED}Failed to download binary from $repo${NC}"
        echo -e "${YELLOW}You may need to manually select the asset or check if the repository has releases${NC}"
    fi
}

# Main execution
main() {
    echo -e "${GREEN}=== GitHub Release Downloader ===${NC}"
    echo ""

    # Ensure install directory exists
    ensure_install_dir

    # Install dra if not present
    install_dra

    # Array of GitHub repositories to download binaries from in the format  
    # Format: "username/project select_pattern install_file_name"
    # where
    # username/project: GitHub repository in the format "username/project"
    # select_pattern: output of command `dra untag username/project` and select the asset pattern
    # install_file_name: name to save the binary as (e.g., "kubectl") in the `~/.local/bin` directory
    REPOS=(
        # Productivity Tools
        "twpayne/chezmoi chezmoi-linux-amd64 chezmoi"
        # System Tools/Utilities
        "rktr1998/zig-wol zig-wol-x86_64-linux.tar.gz zig-wol"
        "sharkdp/bat bat-v{tag}-x86_64-unknown-linux-gnu.tar.gz bat"
        "ericchiang/pup pup_v{tag}_linux_amd64.zip pup"
        "justjanne/powerline-go powerline-go-linux-amd64 powerline-go"
        "zellij-org/zellij zellij-x86_64-unknown-linux-musl.tar.gz zellij"
        # HTTP Servers
        "m3ng9i/ran ran_linux_amd64.zip ran"
        "caddyserver/caddy caddy_{tag}_linux_amd64.tar.gz caddy"
        # Security Tools
        "FiloSottile/age age-v{tag}-linux-amd64.tar.gz age"
        "gopasspw/gopass gopass-{tag}-linux-amd64.tar.gz gopass"
        "anchore/grype grype_{tag}_linux_amd64.tar.gz grype"
        "anchore/syft syft_{tag}_linux_amd64.tar.gz syft"
        "aquasecurity/trivy trivy_{tag}_Linux-64bit.tar.gz trivy"
        "cloudflare/cfssl cfssl-bundle_{tag}_linux_amd64 cfssl-bundle"
        "cloudflare/cfssl cfssl-certinfo_{tag}_linux_amd64 cfssl-certinfo"
        "cloudflare/cfssl cfssl-newkey_{tag}_linux_amd64 cfssl-newkey"
        "cloudflare/cfssl cfssl-scan_{tag}_linux_amd64 cfssl-scan"
        "cloudflare/cfssl cfssljson_{tag}_linux_amd64 cfssljson"
        "cloudflare/cfssl cfssl_{tag}_linux_amd64 cfssl"
        "cloudflare/cfssl mkbundle_{tag}_linux_amd64 mkbundle"
        "cloudflare/cfssl multirootca_{tag}_linux_amd64 multirootca"
        "FiloSottile/mkcert mkcert-v{tag}-linux-amd64 mkcert"
        # Development, git and diff tools
        "cli/cli gh_{tag}_linux_amd64.tar.gz gh"
        "Wilfred/difftastic difft-x86_64-unknown-linux-gnu.tar.gz difft"
        "jesseduffield/lazygit lazygit_{tag}_linux_x86_64.tar.gz lazygit"
        "jesseduffield/lazydocker lazydocker_{tag}_Linux_x86_64.tar.gz lazydocker"
        "isacikgoz/gitbatch gitbatch_{tag}_linux_amd64.tar.gz gitbatch"
        # JSON/Data Tools
        "antonmedv/fx fx_linux_amd64 fx"
        "PaulJuliusMartinez/jless jless-v{tag}-x86_64-unknown-linux-gnu.zip jless"
        "jqlang/jq jq-linux-amd64 jq"
        # Container Tools
        "containers/podman podman-remote-static-linux_amd64.tar.gz podman"
        "project-zot/zot zb-linux-amd64 zb"
        "project-zot/zot zli-linux-amd64 zli"
        "project-zot/zot zot-linux-amd64 zot"
        "project-zot/zot zxp-linux-amd64 zxp"
        # Infrastructure as Code
        "openbao/openbao bao_{tag}_Linux_x86_64.tar.gz bao"
        "opentofu/opentofu tofu_{tag}_linux_amd64.tar.gz tofu"
        "terraform-linters/tflint tflint_linux_amd64.zip tflint"
        # Gen AI Tools
        "AlexsJones/llmfit llmfit-v{tag}-x86_64-unknown-linux-gnu.tar.gz llmfit"
        # Kubernetes Tools
        "k0sproject/k0s k0s-v{tag}-amd64 k0s"
        "k0sproject/k0sctl k0sctl-linux-amd64 k0sctl"
        "kubernetes-sigs/krew krew-linux_amd64.tar.gz krew"
        "derailed/k9s k9s_Linux_amd64.tar.gz k9s"
        "ahmetb/kubectx kubectx_v{tag}_linux_x86_64.tar.gz kubectx"
        "ahmetb/kubectx kubens_v{tag}_linux_x86_64.tar.gz kubens"
        "kastenhq/kubestr kubestr_{tag}_Linux_amd64.tar.gz kubestr"
    )

    # Check if repos array is empty
    if [ ${#REPOS[@]} -eq 0 ]; then
        echo -e "${YELLOW}No repositories configured in REPOS array${NC}"
        echo -e "${YELLOW}Edit this script and add repositories to download${NC}"
        echo ""
        echo "Example usage:"
        echo "  REPOS=("
        echo "    \"junegunn/fzf\""
        echo "    \"BurntSushi/ripgrep\""
        echo "    \"sharkdp/fd\""
        echo "  )"
        exit 0
    fi

    echo -e "${GREEN}Downloading binaries from ${#REPOS[@]} repositories...${NC}"
    echo ""

    # Iterate through repositories and download binaries
    for repo in "${REPOS[@]}"; do
        # Skip empty lines or comments
        [[ -z "$repo" || "$repo" =~ ^#.*$ ]] && continue

        echo "---"
        # Note: do not add quotes around repo variable, we want word splitting to happen
        download_github_binary $repo
        echo ""
    done

    echo ""
    echo -e "${GREEN}All binaries are installed in: $INSTALL_DIR${NC}"
}

# Run main function
main
